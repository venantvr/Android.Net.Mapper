<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.NetMapper" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">#0A84FF</item>
        <item name="colorPrimaryVariant">#0066CC</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">#4CAF50</item>
        <item name="colorSecondaryVariant">#388E3C</item>
        <item name="colorOnSecondary">#FFFFFF</item>

        <!-- Background -->
        <item name="android:windowBackground">#080F18</item>
        <item name="android:colorBackground">#080F18</item>
        <item name="colorSurface">#0D1B2A</item>
        <item name="colorOnSurface">#FFFFFF</item>

        <!-- Status bar and navigation bar -->
        <item name="android:statusBarColor">#050C14</item>
        <item name="android:navigationBarColor">#050C14</item>

        <!-- Bottom navigation -->
        <item name="bottomNavigationStyle">@style/Widget.NetMapper.BottomNavigation</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#AAAAAA</item>

        <!-- EditText style -->
        <item name="editTextStyle">@style/Widget.NetMapper.EditText</item>
    </style>

    <style name="Widget.NetMapper.BottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">#050C14</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <style name="Widget.NetMapper.EditText" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/input_bg</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textColorHint">#666666</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="Widget.NetMapper.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">#0A84FF</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="cornerRadius">8dp</item>
    </style>

</resources>
