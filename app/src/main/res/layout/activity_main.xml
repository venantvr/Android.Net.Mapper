<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080F18">

    <FrameLayout
        android:id="@+id/content_frame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Tab 1: Scan -->
        <ScrollView
            android:id="@+id/view_scan"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvSsid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📶 --"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvBssid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="AP : --"
                    android:textColor="#AAAAAA"
                    android:fontFamily="monospace"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvSubnetInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="IP : --"
                    android:textColor="#AAAAAA"
                    android:fontFamily="monospace"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvGateway"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="GW : --"
                    android:textColor="#AAAAAA"
                    android:fontFamily="monospace"
                    android:textSize="12sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#1E2E3E" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Plage réseau"
                    android:textColor="#7CB8FF"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etSubnet"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="2"
                        android:background="@drawable/input_bg"
                        android:hint="192.168.1"
                        android:inputType="text"
                        android:padding="12dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#666666"
                        android:fontFamily="monospace" />

                    <EditText
                        android:id="@+id/etMask"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/input_bg"
                        android:hint="255.255.255.0"
                        android:inputType="text"
                        android:padding="12dp"
                        android:text="255.255.255.0"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#666666"
                        android:fontFamily="monospace"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Profil de scan"
                    android:textColor="#7CB8FF"
                    android:textSize="14sp" />

                <RadioGroup
                    android:id="@+id/rgProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rbPing"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Ping"
                        android:textColor="#FFFFFF"
                        android:buttonTint="#0A84FF" />

                    <RadioButton
                        android:id="@+id/rbQuick"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Quick"
                        android:textColor="#FFFFFF"
                        android:buttonTint="#0A84FF"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/rbFull"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Full"
                        android:textColor="#FFFFFF"
                        android:buttonTint="#0A84FF" />
                </RadioGroup>

                <CheckBox
                    android:id="@+id/cbBanners"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Banner grabbing (HTTP, SSH, FTP)"
                    android:textColor="#AAAAAA"
                    android:buttonTint="#0A84FF"
                    android:checked="true" />

                <CheckBox
                    android:id="@+id/cbDiscovery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Discovery (mDNS, UPnP, SNMP)"
                    android:textColor="#AAAAAA"
                    android:buttonTint="#0A84FF"
                    android:checked="true" />

                <Button
                    android:id="@+id/btnScan"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="#0A84FF"
                    android:text="🔍 Lancer le scan"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:textSize="16sp" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:indicatorColor="#0A84FF"
                    app:trackColor="#1A2A3A"
                    app:trackCornerRadius="2dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text=""
                    android:textColor="#4CAF50"
                    android:textAlignment="center"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Log"
                    android:textColor="#7CB8FF"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/log_bg"
                    android:fontFamily="monospace"
                    android:minHeight="120dp"
                    android:padding="12dp"
                    android:text=""
                    android:textColor="#4CAF50"
                    android:textSize="11sp"
                    android:gravity="top" />

            </LinearLayout>
        </ScrollView>

        <!-- Tab 2: Devices -->
        <LinearLayout
            android:id="@+id/view_devices"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/etFilter"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_bg"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="8dp"
                android:drawableTint="#666666"
                android:hint="Filtrer par IP, MAC, hostname, OS..."
                android:inputType="text"
                android:padding="12dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDevices"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingBottom="8dp" />

        </LinearLayout>

        <!-- Tab 3: Map -->
        <ScrollView
            android:id="@+id/view_map"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/mapContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Topologie réseau"
                    android:textColor="#7CB8FF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvMapEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:gravity="center"
                    android:text="Lancez un scan pour visualiser la topologie"
                    android:textColor="#666666"
                    android:textSize="14sp" />

            </LinearLayout>
        </ScrollView>

        <!-- Tab 4: Settings & Tools -->
        <ScrollView
            android:id="@+id/view_settings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- MAC Lookup -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔍 Recherche MAC (OUI)"
                    android:textColor="#7CB8FF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etMacLookup"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/input_bg"
                        android:hint="AA:BB:CC:DD:EE:FF"
                        android:inputType="text"
                        android:padding="12dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#666666"
                        android:fontFamily="monospace" />

                    <Button
                        android:id="@+id/btnMacLookup"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="#0A84FF"
                        android:text="Lookup"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvMacResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/log_bg"
                    android:fontFamily="monospace"
                    android:padding="12dp"
                    android:text=""
                    android:textColor="#4CAF50"
                    android:textSize="13sp"
                    android:minHeight="48dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="#1E2E3E" />

                <!-- Network Tools -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🛠 Outils réseau"
                    android:textColor="#7CB8FF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Ping -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etPingHost"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="@drawable/input_bg"
                        android:hint="IP ou hostname"
                        android:inputType="text"
                        android:padding="10dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#666666"
                        android:fontFamily="monospace"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btnPing"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="#2E7D32"
                        android:text="Ping"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Traceroute -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etTracerouteHost"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="@drawable/input_bg"
                        android:hint="8.8.8.8"
                        android:inputType="text"
                        android:padding="10dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#666666"
                        android:fontFamily="monospace"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btnTraceroute"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="#1565C0"
                        android:text="Traceroute"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Wake-on-LAN -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etWolMac"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="@drawable/input_bg"
                        android:hint="AA:BB:CC:DD:EE:FF"
                        android:inputType="text"
                        android:padding="10dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#666666"
                        android:fontFamily="monospace"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btnWol"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="#FF6F00"
                        android:text="WoL"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvToolsResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/log_bg"
                    android:fontFamily="monospace"
                    android:padding="12dp"
                    android:text=""
                    android:textColor="#4CAF50"
                    android:textSize="11sp"
                    android:minHeight="80dp"
                    android:gravity="top" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="#1E2E3E" />

                <!-- Discovery Tools -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔎 Discovery"
                    android:textColor="#7CB8FF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Scan réseau pour services mDNS/Bonjour, UPnP et SNMP"
                    android:textColor="#666666"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnMdnsScan"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:backgroundTint="#E91E63"
                        android:text="mDNS"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/btnUpnpScan"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="#9C27B0"
                        android:text="UPnP"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/btnSnmpScan"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="#3F51B5"
                        android:text="SNMP"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDiscoveryResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/log_bg"
                    android:fontFamily="monospace"
                    android:padding="12dp"
                    android:text=""
                    android:textColor="#4CAF50"
                    android:textSize="11sp"
                    android:minHeight="80dp"
                    android:gravity="top" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="#1E2E3E" />

                <!-- Export -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📤 Export"
                    android:textColor="#7CB8FF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnExportJson"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:backgroundTint="#7B1FA2"
                        android:text="Export JSON"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btnExportCsv"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="#00695C"
                        android:text="Export CSV"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false"
                        android:textSize="13sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="#1E2E3E" />

                <!-- Stats -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📊 Statistiques"
                    android:textColor="#7CB8FF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/log_bg"
                    android:fontFamily="monospace"
                    android:padding="12dp"
                    android:text="Hôtes scannés : 0\nPorts ouverts : 0\nMémorisés : 0\nEntrées OUI : 0"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp" />

            </LinearLayout>
        </ScrollView>

    </FrameLayout>

    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#050C14"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/nav_scan"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/nav_scan_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_scan" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan"
                android:textColor="#0A84FF"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_devices"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/nav_devices_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_devices" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Appareils"
                android:textColor="#666666"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_map"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/nav_map_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_map" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carte"
                android:textColor="#666666"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/nav_settings_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Config"
                android:textColor="#666666"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
